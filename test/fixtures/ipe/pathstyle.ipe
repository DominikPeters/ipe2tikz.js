<ipe version="70200" creator="ipe2tikz-test">
  <ipestyle name="base-pathstyle">
    <pathstyle cap="1" join="1" fillrule="eofill" />
  </ipestyle>
  <ipestyle name="override-pathstyle">
    <pathstyle join="2" />
  </ipestyle>
  <page>
