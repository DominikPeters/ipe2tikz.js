<ipe version="70200" creator="ipe2tikz-test">
  <ipestyle name="fidelity-arrow-kinds">
    <color name="grid" value="0.86" />
    <color name="major" value="0.68" />
    <color name="ink" value="0.02 0.16 0.24" />
    <color name="label" value="0.10 0.10 0.10" />
    <pen name="gridpen" value="0.18" />
    <pen name="majorpen" value="0.35" />
    <pen name="linepen" value="1.2" />
    <textsize name="caption" value="8" />
    <arrowsize name="normal" value="14" />
    <arrowsize name="large" value="20" />
    <symbol name="arrow/normal(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="sym-stroke">
        0 0 m -1 0.35 l -1 -0.35 l h
      </path>
    </symbol>
    <symbol name="arrow/fnormal(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="white">
        0 0 m -1 0.35 l -1 -0.35 l h
      </path>
    </symbol>
    <symbol name="arrow/pointed(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="sym-stroke">
        0 0 m -1 0.35 l -0.78 0 l -1 -0.35 l h
      </path>
    </symbol>
    <symbol name="arrow/fpointed(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="white">
        0 0 m -1 0.35 l -0.78 0 l -1 -0.35 l h
      </path>
    </symbol>
    <symbol name="arrow/arc(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="sym-stroke">
        0 0 m -0.95 0.30 l -0.95 -0.30 l h
      </path>
    </symbol>
    <symbol name="arrow/farc(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="white">
        0 0 m -0.95 0.30 l -0.95 -0.30 l h
      </path>
    </symbol>
    <symbol name="arrow/ptarc(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="sym-stroke">
        0 0 m -0.95 0.30 l -0.72 0 l -0.95 -0.30 l h
      </path>
    </symbol>
    <symbol name="arrow/fptarc(spx)">
      <path pen="sym-pen" stroke="sym-stroke" fill="white">
        0 0 m -0.95 0.30 l -0.72 0 l -0.95 -0.30 l h
      </path>
    </symbol>
  </ipestyle>
