{
  "name": "ipe2tikz",
  "version": "1.0.0",
  "description": "Clean-room Ipe XML to TikZ converter for JavaScript and TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser/ipe2tikz.js",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "ipe2tikz": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "demo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/index.ts --bundle --format=esm --platform=browser --outfile=dist/browser/ipe2tikz.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run check && npm test && npm run smoke:package",
    "smoke:package": "node scripts/smoke-package-bin.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "compare:ipe": "tsx scripts/compare-ipe-import.ts"
  },
  "keywords": [
    "ipe",
    "tikz",
    "latex",
    "converter",
    "graphics"
  ],
  "author": "Dominik Peters",
  "license": "MIT",
  "homepage": "https://github.com/DominikPeters/ipe2tikz.js#readme",
  "bugs": {
    "url": "https://github.com/DominikPeters/ipe2tikz.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DominikPeters/ipe2tikz.js.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.2"
  }
}
